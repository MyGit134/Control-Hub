PORT=8080
JWT_SECRET=change-me
# Optional: 32-byte base64 key. If omitted, will derive from JWT_SECRET
DATA_ENC_KEY=base64-32-bytes
# Where DB file is stored
DB_FILE=./data/app.db
# Admin bootstrap (created if no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me
# Set to 1 when running behind HTTPS (recommended)
COOKIE_SECURE=1
