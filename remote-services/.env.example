SSH_HOST=your-vps-ip
SSH_PORT=22
SSH_USER=controller
SSH_PASSWORD=change-me
# Ports to reverse-forward (remote:local), comma or space separated
TUNNEL_PORTS=6080:6080,3000:3000,8888:8888,8889:8889,8554:8554
# Local host for services (usually 127.0.0.1 on managed machine)
LOCAL_HOST=127.0.0.1
# Bind address on VPS for forwarded ports (keep 127.0.0.1 for safety)
REMOTE_BIND_HOST=127.0.0.1
